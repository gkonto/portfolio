{{define "base"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{block "title" .}}Portfolio{{end}}</title>
  <link rel="stylesheet" href="/static/css/main.css">
  {{block "head" .}}{{end}}
</head>
<body>
  <header class="site-header">
    <div class="shell">
      <p class="site-kicker">$ go run ./cmd/web</p>
      <h1 class="site-title">giorgos_kontogiannis</h1>
      <p class="site-subtitle">// building backend systems in Go with a programmer-first mindset</p>
      {{template "nav" .}}
    </div>
  </header>

  <main class="site-main">
    {{block "main" .}}{{end}}
  </main>

  <footer class="site-footer">
    <div class="shell footer-inner">
      <p>status: online</p>
      <p>stack: Go / net-http / html-template</p>
    </div>
  </footer>
</body>
</html>
{{end}}
