{{define "base"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{block "title" .}}Portfolio{{end}}</title>
  <link rel="stylesheet" href="/static/css/main.css">
  {{block "head" .}}{{end}}
</head>
<body class="{{block "body_class" .}}page{{end}}">
  <div class="page-aura page-aura-left" aria-hidden="true"></div>
  <div class="page-aura page-aura-right" aria-hidden="true"></div>

  <header class="site-header">
    <div class="shell">
      {{template "nav" .}}
    </div>
  </header>

  <main class="site-main">
    {{block "main" .}}{{end}}
  </main>

  <footer class="site-footer">
    <div class="shell footer-inner">
      <p>Built with Go, templates, and a small amount of progressive enhancement.</p>
      <p>Designed to foreground backend engineering work.</p>
    </div>
  </footer>

  <script src="/static/js/main.js" defer></script>
</body>
</html>
{{end}}
